[provider]
default_model = "zai/glm-4.7"

[provider.providers.zai]
base_url = "https://api.z.ai/api/coding/paas/v4"
api_key_env = "ZAI_API_KEY"

[[provider.providers.zai.models]]
id = "glm-4.7"
modality = "text"
max_context_size = 128000

[agent]
max_steps = 0
token_budget = 32000

[tools]
fs = true
bash = true
web = true

[permission]
read = "allow"
list = "allow"
glob = "allow"
grep = "allow"
write = "ask"
bash = "ask"
web = "ask"

[session]
root = "~/.local/state/hh/sessions"
